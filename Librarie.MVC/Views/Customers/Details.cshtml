@model Librarie.Domain.Customer

@{
    ViewData["Title"] = "Customer Details";
}

<h1>Customer Details</h1>

<div class="mb-3">
    <strong>Customer Id:</strong> @Model.Id
</div>
<div class="mb-3">
    <strong>Name:</strong> @Model.Name
</div>

<h2>Invoices</h2>

@if (Model.Invoices == null || !Model.Invoices.Any())
{
    <p>No invoices found for this customer.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Invoice Id</th>
                <th>Date</th>
                <th>Total</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var invoice in Model.Invoices)
            {
                var invoiceTotal = (invoice.Lines?.Sum(l => l.Quantity * l.UnitPrice)) ?? 0m;
                <tr>
                    <td>@invoice.Id</td>
                    <td>@invoice.InvoiceDate.ToShortDateString()</td>
                    <td>@invoiceTotal.ToString("C")</td>
                    <td>
                        <a asp-controller="Invoices" asp-action="Details" asp-route-id="@invoice.Id" class="btn btn-link">View</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<a asp-action="Index" class="btn btn-secondary">Back</a>